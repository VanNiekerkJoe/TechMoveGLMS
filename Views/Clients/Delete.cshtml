@model TechMoveGLMS.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Client
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this client?</h5>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Contact Details</dt>
                    <dd class="col-sm-8">@Model.ContactDetails</dd>

                    <dt class="col-sm-4">Region</dt>
                    <dd class="col-sm-8">@Model.Region</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ClientId" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>