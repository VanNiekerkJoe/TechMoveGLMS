@model TechMoveGLMS.Models.Client
@{
    ViewData["Title"] = "New Client";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold">Create Client</div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Company name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactDetails" class="form-label"></label>
                        <input asp-for="ContactDetails" class="form-control" placeholder="Email / Phone" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Region" class="form-label"></label>
                        <input asp-for="Region" class="form-control" placeholder="e.g. Johannesburg" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill">Create Client</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>