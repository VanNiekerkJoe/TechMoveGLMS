@model IEnumerable<TechMoveGLMS.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
    <h2 class="fw-semibold" style="color: #34495E;"><i class="fas fa-users me-2"></i>Clients</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill"><i class="fas fa-plus me-1"></i> New Client</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Region</th>
                    <th style="width:80px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td>@client.Name</td>
                        <td>@client.ContactDetails</td>
                        <td>@client.Region</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>