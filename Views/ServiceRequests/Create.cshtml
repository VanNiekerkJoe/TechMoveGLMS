@model TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "New Service Request";
    var exchangeRate = ViewBag.ExchangeRate ?? 16.55m;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-white fw-bold">Create Service Request <span class="badge bg-info text-dark ms-2">Live USD/ZAR: @exchangeRate.ToString("N4")</span></div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="ContractId" class="form-label"></label>
                        <select asp-for="ContractId" asp-items="ViewBag.ContractId" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CostUSD" class="form-label">Amount (USD)</label>
                        <input asp-for="CostUSD" id="costUSD" class="form-control" step="0.01" placeholder="0.00" />
                    </div>
                    <input type="hidden" asp-for="CostZAR" id="costZAR" />
                    <div class="mb-4">
                        <label class="form-label">Amount (ZAR) – estimated</label>
                        <input id="estimatedZAR" class="form-control bg-light" readonly placeholder="Will auto-calculate" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill">Create Request</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const rate = @exchangeRate;
        const usdInput = document.getElementById('costUSD');
        const zarHidden = document.getElementById('costZAR');
        const estimated = document.getElementById('estimatedZAR');

        function updateZar() {
            let usd = parseFloat(usdInput.value) || 0;
            let zar = usd * rate;
            estimated.value = zar.toFixed(2);
            zarHidden.value = zar.toFixed(2);
        }
        usdInput.addEventListener('input', updateZar);
        updateZar();
    </script>
}