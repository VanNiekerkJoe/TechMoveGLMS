@model TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Service Request
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this service request?</h5>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Contract</dt>
                    <dd class="col-sm-8">@Model.Contract?.ServiceLevel</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Cost (USD)</dt>
                    <dd class="col-sm-8">$@Model.CostUSD.ToString("N2")</dd>

                    <dt class="col-sm-4">Cost (ZAR)</dt>
                    <dd class="col-sm-8">R @Model.CostZAR.ToString("N2")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Created Date</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToShortDateString()</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ServiceRequestId" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>