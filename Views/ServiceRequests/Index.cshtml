@model IEnumerable<TechMoveGLMS.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-semibold"><i class="fas fa-headset me-2"></i>Service Requests</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill"><i class="fas fa-plus me-1"></i> New Request</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Contract</th><th>Description</th><th>Cost (USD)</th><th>Cost (ZAR)</th><th>Status</th><th>Date</th></tr>
            </thead>
            <tbody>
                @foreach (var sr in Model)
                {
                    <tr>
                        <td>@sr.Contract?.ServiceLevel</td>
                        <td>@sr.Description</td>
                        <td>$@sr.CostUSD.ToString("N2")</td>
                        <td>R@sr.CostZAR.ToString("N2")</td>
                        <td><span class="badge-status">@sr.Status</span></td>
                        <td>@sr.CreatedDate.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>