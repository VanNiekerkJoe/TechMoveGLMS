@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Delete Contract
            </div>
            <div class="card-body">
                <h5>Are you sure you want to delete this contract?</h5>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Client</dt>
                    <dd class="col-sm-8">@Model.Client?.Name</dd>

                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToShortDateString()</dd>

                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToShortDateString()</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Service Level</dt>
                    <dd class="col-sm-8">@Model.ServiceLevel</dd>

                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <dt class="col-sm-4">Signed Agreement</dt>
                        <dd class="col-sm-8">
                            <a asp-action="Download" asp-route-filePath="@Model.SignedAgreementPath" class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-download"></i> Download PDF
                            </a>
                        </dd>
                    }
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ContractId" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-times me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>